{
  "name": "topthink/think-orm",
  "description": "the PHP Database&ORM Framework",
  "replace": {
    "topthink/think-orm": "^3.0"
  },
  "keywords": [
    "orm",
    "database"
  ],
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "liu21st",
      "email": "liu21st@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.0.0",
    "ext-json": "*",
    "ext-pdo": "*",
    "psr/simple-cache": ">=1.0",
    "psr/log": ">=1.0",
    "topthink/think-helper": "^3.1"
  },
  "require-dev": {
    "bamarni/composer-bin-plugin": "^1.8",
    "friendsofphp/php-cs-fixer": "^3.95",
    "phpstan/phpstan": "^2.2",
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "think\\": "src"
    },
    "files": [
      "stubs/load_stubs.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "tests\\": "tests"
    }
  },
  "suggest": {
    "ext-mongodb": "provide mongodb support"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@composer bin phinx install --ansi"
    ],
    "phinx-update": [
      "@composer bin phinx update --ansi"
    ],
    "db-migrate": [
      "./vendor/bin/phinx migrate -e mysql -vvv",
      "./vendor/bin/phinx migrate -e pgsql -vvv"
    ],
    "db-rollback": [
      "./vendor/bin/phinx rollback -f -e mysql",
      "./vendor/bin/phinx rollback -f -e pgsql"
    ],
    "db-status": [
      "./vendor/bin/phinx status -e mysql",
      "./vendor/bin/phinx status -e pgsql"
    ],
    "db-rebuild": [
      "@composer run db-rollback",
      "@composer run db-migrate"
    ],
    "test": "phpunit --testsuite Integration",
    "test:unit": "phpunit --testsuite Unit",
    "test:integration": "phpunit --testsuite Integration",
    "test:all": "phpunit --testsuite All",
    "fix-style": "php-cs-fixer fix",
    "check-style": "php-cs-fixer fix --dry-run",
    "analyze": "phpstan --no-progress --memory-limit=1G"
  },
  "extra": {
    "bamarni-bin": {
      "bin-links": true,
      "forward-command": false
    }
  }
}